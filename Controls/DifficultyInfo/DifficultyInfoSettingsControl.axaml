<ci:ComponentBase
    x:Class="ClassIsland.AISmartClass.Controls.DifficultyInfo.DifficultyInfoSettingsControl"
    x:TypeArguments="models:DifficultyInfoSettings"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ci="clr-namespace:ClassIsland.Core.Abstractions.Controls;assembly=ClassIsland.Core"
    xmlns:local="clr-namespace:ClassIsland.AISmartClass.Controls.DifficultyInfo"
    xmlns:models="clr-namespace:ClassIsland.AISmartClass.Models">
    <ScrollViewer DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:DifficultyInfoSettingsControl}}">
        <StackPanel Spacing="12" Margin="8">
            <TextBlock Text="显示项" FontWeight="Bold"/>
            <CheckBox Content="显示难度星数" IsChecked="{Binding Settings.ShowDifficulty, Mode=TwoWay}"/>
            <CheckBox Content="显示番茄钟建议" IsChecked="{Binding Settings.ShowPomodoro, Mode=TwoWay}"/>
            <Separator/>
            <TextBlock Text="字体大小" FontWeight="Bold"/>
            <Grid ColumnDefinitions="*,160">
                <TextBlock Text="正文字号" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="10" Maximum="24"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Value="{Binding Settings.FontSize, Mode=TwoWay}"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</ci:ComponentBase>
