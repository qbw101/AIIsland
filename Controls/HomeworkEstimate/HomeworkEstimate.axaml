<ci:ComponentBase
    x:Class="ClassIsland.AISmartClass.Controls.HomeworkEstimate.HomeworkEstimate"
    x:TypeArguments="models:HomeworkEstimateSettings"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ci="http://classisland.tech/schemas/xaml/core"
    xmlns:models="clr-namespace:ClassIsland.AISmartClass.Models"
    FontSize="{Binding Settings.FontSize, FallbackValue=14}">

    <Border CornerRadius="8" Padding="12,8"
            Background="{DynamicResource SystemControlBackgroundListLowBrush}">
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <TextBlock Text="📝" FontSize="18" VerticalAlignment="Center"/>
            <StackPanel Spacing="1" VerticalAlignment="Center">
                <TextBlock Text="作业量预估" FontSize="11" Opacity="0.6"/>
                <TextBlock Text="{Binding Estimate}"
                           TextWrapping="Wrap" MaxLines="2"
                           TextTrimming="CharacterEllipsis"
                           FontWeight="Medium" LineHeight="18"/>
            </StackPanel>
        </StackPanel>
    </Border>
</ci:ComponentBase>
