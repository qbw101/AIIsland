<Window
    x:Class="ClassIsland.AISmartClass.Views.CustomReminderEditDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="编辑自定义提醒"
    Width="520" Height="640"
    MinWidth="500" MinHeight="560"
    CanResize="True"
    WindowStartupLocation="CenterOwner"
    Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
    FontFamily="Microsoft YaHei,Segoe UI,sans-serif">

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorSecondaryBrush}"/>
        </Style>
        <Style Selector="Button.primary:pressed">
            <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorTertiaryBrush}"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="ComboBox:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
        </Style>
        <Style Selector="ComboBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="160"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="NumericUpDown Button">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="13"/>
        </Style>
        <Style Selector="NumericUpDown TextBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="MinWidth" Value="50"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style Selector="DatePicker">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Border.form-card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.error">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0">
            <StackPanel Spacing="16" Margin="24,20,24,16">
                <StackPanel Spacing="4">
                    <TextBlock Text="编辑自定义提醒" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="选择触发方式并填写提醒内容。固定时间只触发一次，每日重复每天触发一次。"
                               FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                </StackPanel>

                <Border Classes="form-card">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="label" Text="提醒类型"/>
                            <ComboBox x:Name="TypeCombo" SelectedIndex="0" HorizontalAlignment="Stretch">
                                <ComboBoxItem>固定日期+时间</ComboBoxItem>
                                <ComboBoxItem>关联科目（课前提醒）</ComboBoxItem>
                                <ComboBoxItem>每日重复时间</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel x:Name="DateSection" Spacing="6">
                            <TextBlock Classes="label" Text="日期"/>
                            <DatePicker x:Name="DatePicker" HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel x:Name="TimeSection" Spacing="6">
                            <TextBlock Classes="label" Text="时间"/>
                            <Grid ColumnDefinitions="160,Auto,160" ColumnSpacing="10" HorizontalAlignment="Left">
                                <NumericUpDown x:Name="HourBox" Minimum="0" Maximum="23" Value="8" FormatString="00"/>
                                <TextBlock Grid.Column="1" Text=":" FontSize="18" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" FontWeight="SemiBold"/>
                                <NumericUpDown Grid.Column="2" x:Name="MinuteBox" Minimum="0" Maximum="59" Value="0" FormatString="00"/>
                            </Grid>
                            <TextBlock Text="使用 24 小时制填写小时和分钟。" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel x:Name="SubjectSection" Spacing="6" IsVisible="False">
                            <TextBlock Classes="label" Text="关联科目"/>
                            <TextBox x:Name="SubjectBox" Watermark="例如：数学、英语、物理"/>
                        </StackPanel>

                        <StackPanel x:Name="MinutesSection" Spacing="6" IsVisible="False">
                            <TextBlock Classes="label" Text="提前多少分钟提醒"/>
                            <NumericUpDown x:Name="MinutesBeforeBox" Minimum="0" Maximum="120" Value="3" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Classes="form-card">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="label" Text="提醒内容"/>
                            <TextBox x:Name="ContentBox" Watermark="例如：带数学作业本 / 记得喝水" MinHeight="82"
                                     AcceptsReturn="True" TextWrapping="Wrap"/>
                        </StackPanel>
                        <CheckBox x:Name="EnabledCb" Content="启用此提醒" IsChecked="True"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="ErrorText" Classes="error" IsVisible="False" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Padding="20,12" Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button x:Name="CancelBtn" Content="取消" MinWidth="84" Click="OnCancelClicked"/>
                <Button x:Name="OkBtn" Content="确定" MinWidth="84" Classes="primary" Click="OnOkClicked"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
